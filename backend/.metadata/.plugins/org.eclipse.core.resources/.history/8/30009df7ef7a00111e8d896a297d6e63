package br.com.muniz.academiagit.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.CrossOrigin;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import br.com.muniz.academiagit.model.ModalidadeModel;
import br.com.muniz.academiagit.service.ModalidadeService;

@RestController
@RequestMapping("/modalidades")
@CrossOrigin(originPatterns = "*")
public class ModalidadeController {
	
	@Autowired
	private ModalidadeService service;
	
	@PostMapping
	public ModalidadeModel salvarModalidade(@RequestBody ModalidadeModel modalidade) {
		return service.salvarModalidade(modalidade);		
	}
	
	@GetMapping()
	public List<ModalidadeModel> listarModalidade(){
		return service.listarModalidade();		
	}
	

}
